{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cairn-manager",
  "version": "0.1.0",
  "identifier": "com.dustin.cairn-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "cairn-manager",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nxm"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/CairnModding/CairnModManager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2MEZCMjRBOENDRDM0RjUKUldUMU5NMk1TcklQMXFzVm1ack9JRmhoczlFMlJGUGt3UmpzSlpPVjVZZ1MyUUtLQ2t2UlN5enIK"
    }
  }
}
